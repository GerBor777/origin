# Используем базовый образ Ubuntu 16.04
FROM ubuntu:16.04

# Устанавливаем g++ (компилятор C++)
RUN apt update && apt install -y g++

# Создаём рабочую папку внутри контейнера
WORKDIR /app

# Копируем файл с исходным кодом внутрь контейнера
COPY hello.cpp .

# Компилируем программу
RUN g++ hello.cpp -o hello.exe

# Указываем команду для запуска программы при старте контейнера
CMD ["./hello.exe"]